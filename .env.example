# Copy to .env.local and fill in real values. .env.local is gitignored.

DATABASE_URL="postgresql://user:password@127.0.0.1:5432/febocolour"

# Public site URL — used for canonical URLs, sitemap.xml, and OG metadata
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# SMTP — order confirmation (customer) + new-order alert (admin) emails.
# For local dev, run a Maildev catcher and point at it (no real credentials needed):
#   docker run -d --name febocolour-maildev -p 1025:1025 -p 1080:1080 maildev/maildev
#   Web UI: http://localhost:1080
SMTP_HOST="127.0.0.1"
SMTP_PORT="1025"
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM_EMAIL="orders@febocolour.com"
SMTP_FROM_NAME="FeboColour"
ADMIN_NOTIFICATION_EMAIL="admin@febocolour.com"
